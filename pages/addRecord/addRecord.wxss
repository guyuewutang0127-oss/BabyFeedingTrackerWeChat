/* 添加记录页样式 */

.container {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background: #FFF5F7;
}

.form-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 32rpx;
}

.card-title-icon {
  width: 8rpx;
  height: 32rpx;
  background: #FF6B8A;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.form-label.required::after {
  content: '*';
  color: #FF4D4F;
  margin-left: 8rpx;
}

.datetime-picker {
  display: flex;
  gap: 24rpx;
}

.datetime-picker picker {
  flex: 1;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.picker-item.error {
  border-color: #FF4D4F;
  background: rgba(255, 77, 79, 0.05);
}

.picker-text {
  font-size: 28rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999999;
}

.form-input {
  width: 100%;
  min-height: 80rpx;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333333;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.form-input.error {
  border-color: #FF4D4F;
  background: rgba(255, 77, 79, 0.05);
}

.form-input::placeholder {
  color: #CCCCCC;
}

.form-textarea {
  width: 100%;
  min-height: 280rpx;
  height: 280rpx;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
  line-height: 1.5;
}

.form-textarea::placeholder {
  color: #CCCCCC;
}

.input-hint {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
}

.error-text {
  display: block;
  font-size: 24rpx;
  color: #FF4D4F;
  margin-top: 12rpx;
}

/* 按钮组 */
.button-group {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 0;
}

.button-group .btn {
  flex: 1;
}

.btn {
  padding: 28rpx 0;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8FA3 100%);
  color: #FFFFFF;
}

.btn-secondary {
  background: #F5F5F5;
  color: #666666;
}
