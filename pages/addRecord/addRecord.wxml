<view class="container">
  <view class="form-card">
    <view class="card-title">
      <view class="card-title-icon"></view>
      <text>喂养信息</text>
    </view>
    
    <!-- 喂养时间 -->
    <view class="form-item">
      <text class="form-label required">喂养时间</text>
      <view class="datetime-picker">
        <picker mode="date" value="{{feedingDate}}" bindchange="onDateChange">
          <view class="picker-item {{errors.feedingDate ? 'error' : ''}}">
            <text class="picker-text">{{feedingDate || '选择日期'}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
        <picker mode="time" value="{{feedingTime}}" bindchange="onTimeChange">
          <view class="picker-item {{errors.feedingTime ? 'error' : ''}}">
            <text class="picker-text">{{feedingTime || '选择时间'}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
      <text class="error-text" wx:if="{{errors.feedingDate}}">{{errors.feedingDate}}</text>
    </view>

    <!-- 喂养类型 -->
    <view class="form-item">
      <text class="form-label required">喂养类型</text>
      <picker bindchange="onTypeChange" value="{{feedingTypeIndex}}" range="{{feedingTypeOptions}}" range-key="label">
        <view class="picker-item">
          <text class="picker-text">{{feedingTypeOptions[feedingTypeIndex] && feedingTypeOptions[feedingTypeIndex].label || '奶粉'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- 冲泡量（非母乳且非补喝时显示） -->
    <view class="form-item" wx:if="{{feedingType !== 'breastfeeding' && feedingType !== 'supplement'}}">
      <text class="form-label">冲泡量 (ml)</text>
      <input 
        class="form-input {{errors.preparedAmount ? 'error' : ''}}"
        type="number"
        placeholder="请输入冲泡量"
        value="{{preparedAmount}}"
        bindinput="onPreparedAmountInput"
      />
      <text class="input-hint">可选，用于记录冲泡了多少奶</text>
    </view>

    <!-- 奶量：补喝时仅此项+时间；非母乳时为实际奶量 -->
    <view class="form-item" wx:if="{{feedingType !== 'breastfeeding'}}">
      <text class="form-label required">{{feedingType === 'supplement' ? '奶量 (ml)' : '实际奶量 (ml)'}}</text>
      <input 
        class="form-input {{errors.actualAmount ? 'error' : ''}}"
        type="number"
        placeholder="{{feedingType === 'supplement' ? '请输入奶量' : '请输入实际喝奶量'}}"
        value="{{actualAmount}}"
        bindinput="onActualAmountInput"
      />
      <text class="error-text" wx:if="{{errors.actualAmount}}">{{errors.actualAmount}}</text>
    </view>

    <!-- 喂养时长（补喝不显示） -->
    <view class="form-item" wx:if="{{feedingType !== 'supplement'}}">
      <text class="form-label">喂养时长 (分钟)</text>
      <input 
        class="form-input"
        type="number"
        placeholder="请输入喂养时长"
        value="{{duration}}"
        bindinput="onDurationInput"
      />
      <text class="input-hint">可选，记录本次喂养用了多长时间</text>
    </view>

    <!-- 备注 -->
    <view class="form-item" wx:if="{{feedingType !== 'supplement'}}">
      <text class="form-label">备注</text>
      <textarea 
        class="form-textarea"
        placeholder="可选，添加备注信息"
        value="{{note}}"
        bindinput="onNoteInput"
        maxlength="100"
      />
    </view>
  </view>

  <!-- 按钮组 -->
  <view class="button-group">
    <button class="btn btn-secondary" bindtap="cancel">取消</button>
    <button class="btn btn-primary" bindtap="saveRecord">保存</button>
  </view>
</view>
