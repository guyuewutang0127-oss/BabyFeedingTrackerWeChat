/* 设置页样式 */

.container {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background: #FFF5F7;
}

.card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 32rpx;
}

.card-title-icon {
  width: 8rpx;
  height: 32rpx;
  background: #FF6B8A;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.form-hint {
  display: block;
  font-size: 24rpx;
  color: #999999;
  line-height: 1.5;
  margin-top: 16rpx;
}

.avatar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-bottom: 16rpx;
}

.avatar-hint {
  font-size: 24rpx;
  color: #999999;
}

.form-input {
  width: 100%;
  min-height: 80rpx;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
}

.picker-text {
  font-size: 28rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999999;
}

.btn {
  width: 100%;
  padding: 28rpx 0;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  margin-top: 24rpx;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8FA3 100%);
  color: #FFFFFF;
}

/* 开关项 */
.switch-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #F5F5F5;
}

.switch-item:last-child {
  border-bottom: none;
}

.switch-info {
  flex: 1;
}

.switch-label {
  display: block;
  font-size: 30rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.switch-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #F5F5F5;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-content {
  flex: 1;
}

.list-item-title {
  display: block;
  font-size: 30rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.list-item-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

.list-item-arrow {
  font-size: 28rpx;
  color: #CCCCCC;
  margin-left: 16rpx;
}
