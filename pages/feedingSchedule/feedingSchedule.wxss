/* 喂养时间表页样式 */

.container {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background: #FFF5F7;
}

/* 开关卡片 */
.switch-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
}

.switch-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.switch-label {
  font-size: 30rpx;
  color: #333333;
}

/* 时间表卡片 */
.schedule-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.card-title-icon {
  width: 8rpx;
  height: 32rpx;
  background: #FF6B8A;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.template-name {
  font-size: 26rpx;
  color: #FF6B8A;
  background: rgba(255, 107, 138, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.schedule-hint {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.sync-row {
  margin-bottom: 20rpx;
}

.sync-btn {
  font-size: 26rpx;
  color: #FF6B8A;
  text-decoration: underline;
}

.sync-btn.disabled {
  color: #CCCCCC;
  text-decoration: none;
}

.schedule-list {
  margin-bottom: 24rpx;
}

.schedule-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #F5F5F5;
}

.schedule-item:last-child {
  border-bottom: none;
}

.schedule-info {
  flex: 1;
}

.schedule-name-time {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.schedule-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333333;
  margin-right: 24rpx;
}

.schedule-time {
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B8A;
}

.schedule-detail {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.schedule-interval {
  font-size: 26rpx;
  color: #FF6B8A;
}

.schedule-amount {
  font-size: 26rpx;
  color: #666666;
}

.schedule-type {
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
}

.tag-breastfeeding {
  background: rgba(255, 182, 193, 0.2);
  color: #FF6B8A;
}

.tag-mixed {
  background: rgba(255, 193, 7, 0.2);
  color: #FFA000;
}

.tag-formula {
  background: rgba(33, 150, 243, 0.2);
  color: #1976D2;
}

.schedule-note {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.schedule-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 26rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.action-btn.edit {
  color: #FF6B8A;
  background: rgba(255, 107, 138, 0.1);
}

.action-btn.delete {
  color: #FF4D4F;
  background: rgba(255, 77, 79, 0.1);
}

/* 添加按钮 */
.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  border: 2rpx dashed #DDDDDD;
}

.add-icon {
  font-size: 36rpx;
  color: #FF6B8A;
  margin-right: 12rpx;
}

.add-text {
  font-size: 28rpx;
  color: #FF6B8A;
}

/* 模板卡片 */
.template-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
}

.template-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.template-item {
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
}

.template-item-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 8rpx;
}

.template-item-desc {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* 模态框 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  background: #FFFFFF;
  border-radius: 32rpx;
  width: 80%;
  max-width: 600rpx;
  overflow: hidden;
}

.modal-header {
  padding: 32rpx;
  text-align: center;
  border-bottom: 2rpx solid #EEEEEE;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.modal-body {
  padding: 32rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.form-label.required::after {
  content: '*';
  color: #FF4D4F;
  margin-left: 8rpx;
}

.form-input {
  width: 100%;
  min-height: 80rpx;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.form-readonly {
  padding: 24rpx;
  background: #F0F0F0;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #666666;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
}

.picker-text {
  font-size: 28rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999999;
}

.modal-footer {
  display: flex;
  border-top: 2rpx solid #EEEEEE;
}

.modal-btn {
  flex: 1;
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  background: transparent;
  border: none;
  border-radius: 0;
}

.modal-btn::after {
  border: none;
}

.modal-btn-cancel {
  color: #666666;
  border-right: 2rpx solid #EEEEEE;
}

.modal-btn-confirm {
  color: #FF6B8A;
  font-weight: 500;
}
