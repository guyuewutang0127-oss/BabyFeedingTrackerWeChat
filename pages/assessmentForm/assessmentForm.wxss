/* 评估问卷页样式 */

.container {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background: #FFF5F7;
}

.form-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 32rpx;
}

.card-title-icon {
  width: 8rpx;
  height: 32rpx;
  background: #FF6B8A;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.form-label.required::after {
  content: '*';
  color: #FF4D4F;
  margin-left: 8rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.picker-item.error {
  border-color: #FF4D4F;
  background: rgba(255, 77, 79, 0.05);
}

.picker-text {
  font-size: 28rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999999;
}

.form-input {
  width: 100%;
  min-height: 80rpx;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333333;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.form-input.error {
  border-color: #FF4D4F;
  background: rgba(255, 77, 79, 0.05);
}

.form-input::placeholder {
  color: #CCCCCC;
}

.form-textarea {
  width: 100%;
  min-height: 280rpx;
  height: 280rpx;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
  line-height: 1.5;
}

.form-textarea::placeholder {
  color: #CCCCCC;
}

.error-text {
  display: block;
  font-size: 24rpx;
  color: #FF4D4F;
  margin-top: 12rpx;
}

/* 复选框 */
.checkbox-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #333333;
}

.checkbox-item checkbox {
  margin-right: 16rpx;
}

/* 按钮组 */
.button-group {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 0;
}

.button-group .btn {
  flex: 1;
}

.btn {
  padding: 28rpx 0;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8FA3 100%);
  color: #FFFFFF;
}

.btn-secondary {
  background: #F5F5F5;
  color: #666666;
}

/* 结果卡片 */
.result-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #EEEEEE;
}

.result-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

.result-date {
  font-size: 26rpx;
  color: #999999;
}

.result-section {
  margin-bottom: 32rpx;
}

.result-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #FF6B8A;
}

/* 生长发育网格 */
.growth-grid {
  display: flex;
  gap: 24rpx;
}

.growth-item {
  flex: 1;
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
}

.growth-label {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.growth-value {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.growth-status {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.growth-status.normal {
  background: rgba(82, 196, 26, 0.1);
  color: #52C41A;
}

.growth-status.mild,
.growth-status.mildHigh {
  background: rgba(250, 173, 20, 0.1);
  color: #FAAD14;
}

.growth-status.moderate,
.growth-status.moderateHigh,
.growth-status.severe,
.growth-status.severeHigh {
  background: rgba(255, 77, 79, 0.1);
  color: #FF4D4F;
}

.growth-percent {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* 喂养结果 */
.feeding-result {
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 24rpx;
}

.feeding-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.feeding-label {
  font-size: 28rpx;
  color: #666666;
  margin-right: 24rpx;
}

.feeding-status {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.feeding-status.normal {
  background: rgba(82, 196, 26, 0.1);
  color: #52C41A;
}

.feeding-status.warning {
  background: rgba(255, 77, 79, 0.1);
  color: #FF4D4F;
}

.suggestion-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

/* 综合建议 */
.overall-suggestion {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 24rpx;
}
