/* 统计页样式 */

.container {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background: #FFF5F7;
}

/* 周期切换 */
.period-tabs {
  display: flex;
  background: #FFFFFF;
  border-radius: 48rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.tab-item {
  flex: 1;
  padding: 20rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #666666;
  border-radius: 40rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8FA3 100%);
  color: #FFFFFF;
  font-weight: 500;
}

/* 统计卡片 */
.stats-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 32rpx;
}

.stats-item {
  text-align: center;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
}

.stats-value {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #FF6B8A;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 26rpx;
  color: #666666;
}

/* 图表卡片 */
.chart-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.card-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 32rpx;
}

.card-title-icon {
  width: 8rpx;
  height: 32rpx;
  background: #FF6B8A;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.chart-container {
  height: 300rpx;
}

.chart-bars {
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 100%;
  padding-bottom: 40rpx;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  height: 100%;
}

.bar-wrapper {
  flex: 1;
  display: flex;
  align-items: flex-end;
  width: 100%;
  justify-content: center;
}

.bar {
  width: 40rpx;
  background: linear-gradient(180deg, #FF6B8A 0%, #FF8FA3 100%);
  border-radius: 8rpx 8rpx 0 0;
  transition: height 0.3s ease;
}

.bar-label {
  font-size: 22rpx;
  color: #999999;
  margin-top: 12rpx;
}

/* 间隔卡片 */
.interval-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.interval-content {
  display: flex;
  justify-content: center;
}

.interval-item {
  text-align: center;
  padding: 32rpx 64rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
}

.interval-label {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.interval-value {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  color: #FF6B8A;
}

/* 建议卡片 */
.suggestion-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
}

.suggestion-list {
  padding: 0 16rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #F5F5F5;
}

.suggestion-item:last-child {
  border-bottom: none;
}

.suggestion-dot {
  font-size: 32rpx;
  color: #FF6B8A;
  margin-right: 16rpx;
  line-height: 1.4;
}

.suggestion-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}
