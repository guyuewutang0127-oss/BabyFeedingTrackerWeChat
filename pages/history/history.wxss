/* 历史记录页样式 */

.container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background: #FFFFFF;
  border-bottom: 2rpx solid #EEEEEE;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  padding: 28rpx 0;
  text-align: center;
  font-size: 30rpx;
  color: #666666;
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: #FF6B8A;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #FF6B8A;
  border-radius: 2rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  margin-bottom: 16rpx;
}

.filter-picker {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #F5F5F5;
  border-radius: 32rpx;
}

.filter-text {
  font-size: 28rpx;
  color: #333333;
  margin-right: 12rpx;
}

.filter-icon {
  font-size: 20rpx;
  color: #999999;
}

.filter-clear {
  margin-left: 24rpx;
  padding: 16rpx 24rpx;
}

.filter-clear text {
  font-size: 28rpx;
  color: #FF6B8A;
}

/* 统计摘要 */
.summary-card {
  display: flex;
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8FA3 100%);
  border-radius: 24rpx;
  margin: 24rpx;
  padding: 32rpx;
}

.summary-item {
  flex: 1;
  text-align: center;
}

.summary-value {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.summary-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 记录列表 */
.records-list {
  padding: 0 24rpx;
}

.date-group {
  margin-bottom: 24rpx;
}

.date-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}

.date-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.date-count {
  font-size: 26rpx;
  color: #999999;
}

.records-container {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
}

.record-item-wrapper {
  position: relative;
  overflow: hidden;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  background: #FFFFFF;
  border-bottom: 2rpx solid #F5F5F5;
  position: relative;
  z-index: 1;
  transition: transform 0.3s ease;
}

.record-item:last-child {
  border-bottom: none;
}

.record-info {
  flex: 1;
}

.record-time-type {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-time {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
  margin-right: 16rpx;
}

.record-type {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tag-breastfeeding {
  background: rgba(255, 182, 193, 0.2);
  color: #FF6B8A;
}

.tag-mixed {
  background: rgba(255, 193, 7, 0.2);
  color: #FFA000;
}

.tag-formula {
  background: rgba(33, 150, 243, 0.2);
  color: #1976D2;
}

.tag-supplement {
  background: rgba(255, 107, 138, 0.2);
  color: #FF6B8A;
}

.record-detail {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.record-detail text {
  font-size: 26rpx;
  color: #666666;
}

.record-note {
  display: block;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 120rpx;
  background: #FF4D4F;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 0;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.delete-btn.show {
  opacity: 1;
}

.delete-text {
  font-size: 28rpx;
  color: #FFFFFF;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
}

.load-more text {
  font-size: 28rpx;
  color: #FF6B8A;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999999;
}

/* 评估档案 */
.section {
  margin: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #FF6B8A;
}

.assessment-list {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
}

.assessment-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 2rpx solid #F5F5F5;
}

.assessment-item:last-child {
  border-bottom: none;
}

.assessment-item.pending {
  background: linear-gradient(90deg, rgba(255, 107, 138, 0.05) 0%, transparent 100%);
}

.assessment-info {
  flex: 1;
}

.assessment-name {
  display: block;
  font-size: 30rpx;
  color: #333333;
  margin-bottom: 8rpx;
}

.assessment-status {
  font-size: 26rpx;
  color: #FF6B8A;
}

.assessment-date {
  font-size: 26rpx;
  color: #999999;
}

.assessment-result {
  display: flex;
  align-items: center;
}

.result-tag {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  margin-right: 16rpx;
}

.result-tag.normal {
  background: rgba(82, 196, 26, 0.1);
  color: #52C41A;
}

.result-tag.malnutrition,
.result-tag.overweight {
  background: rgba(255, 77, 79, 0.1);
  color: #FF4D4F;
}

.assessment-arrow {
  font-size: 28rpx;
  color: #CCCCCC;
}

/* 悬浮按钮 */
.fab {
  position: fixed;
  right: 48rpx;
  bottom: 180rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8FA3 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 138, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 56rpx;
  color: #FFFFFF;
  font-weight: 300;
}

/* 模态框 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  background: #FFFFFF;
  border-radius: 32rpx;
  width: 80%;
  max-width: 600rpx;
  overflow: hidden;
}

.modal-header {
  padding: 32rpx;
  text-align: center;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.modal-body {
  padding: 0 48rpx 48rpx;
}

.modal-text {
  font-size: 30rpx;
  color: #666666;
  line-height: 1.6;
  text-align: center;
}

.modal-footer {
  display: flex;
  border-top: 2rpx solid #EEEEEE;
}

.modal-btn {
  flex: 1;
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  background: transparent;
  border: none;
  border-radius: 0;
}

.modal-btn::after {
  border: none;
}

.modal-btn-cancel {
  color: #666666;
  border-right: 2rpx solid #EEEEEE;
}

.modal-btn-confirm {
  color: #FF4D4F;
  font-weight: 500;
}
