/* 首页样式 */

.container {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background: #FFF5F7;
}

/* 宝宝信息卡片 */
.baby-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8FA3 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.baby-info {
  display: flex;
  align-items: center;
}

.baby-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 24rpx;
}

.baby-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.baby-age {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.feeding-status {
  text-align: right;
}

.status-text {
  font-size: 28rpx;
  font-weight: 500;
}

/* 倒计时卡片 */
.countdown-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.countdown-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.last-feed {
  display: flex;
  flex-direction: column;
}

.last-label {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.last-time {
  font-size: 30rpx;
  color: #333333;
}

.last-amount {
  background: rgba(255, 107, 138, 0.1);
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
}

.amount-value {
  font-size: 28rpx;
  color: #FF6B8A;
  font-weight: 500;
}

.countdown-body {
  margin-top: 16rpx;
}

.countdown-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.countdown-label {
  font-size: 28rpx;
}

.countdown-value {
  font-size: 40rpx;
  font-weight: 600;
}

.progress-bar {
  height: 12rpx;
  background: #F0F0F0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

/* 统计卡片 */
.stats-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.stats-date {
  font-size: 26rpx;
  color: #999999;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stats-item {
  text-align: center;
}

.stats-value {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #FF6B8A;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 26rpx;
  color: #666666;
}

/* 录入方式切换 */
.input-mode-tabs {
  display: flex;
  background: #FFFFFF;
  border-radius: 48rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.tab-item {
  flex: 1;
  padding: 20rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #666666;
  border-radius: 40rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8FA3 100%);
  color: #FFFFFF;
  font-weight: 500;
}

/* 计时卡片 */
.timer-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.timer-display {
  text-align: center;
  padding: 48rpx 0;
}

.timer-value {
  display: block;
  font-size: 80rpx;
  font-weight: 600;
  color: #FF6B8A;
  font-family: 'DIN Alternate', monospace;
  margin-bottom: 16rpx;
}

.timer-label {
  display: block;
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.timer-edit {
  font-size: 26rpx;
  color: #FF6B8A;
  text-decoration: underline;
}

/* 喂养类型选择 */
.feeding-type-section {
  margin-bottom: 24rpx;
}

.section-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.type-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
}

.type-text {
  font-size: 28rpx;
  color: #333333;
}

.type-arrow {
  font-size: 24rpx;
  color: #999999;
}

/* 奶量输入 */
.amount-section {
  margin-bottom: 32rpx;
}

.input-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.input-group {
  flex: 1;
}

.input-label {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.amount-input {
  width: 100%;
  min-height: 80rpx;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  font-size: 32rpx;
  color: #333333;
  text-align: center;
  box-sizing: border-box;
}

.copy-last {
  font-size: 26rpx;
  color: #FF6B8A;
  text-decoration: underline;
}

/* 按钮组 */
.timer-actions {
  display: flex;
  gap: 24rpx;
}

.timer-actions .btn {
  flex: 1;
}

.btn {
  padding: 28rpx 0;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8FA3 100%);
  color: #FFFFFF;
}

.btn-secondary {
  background: #F5F5F5;
  color: #666666;
}

.btn-large {
  width: 100%;
}

/* 文字提取卡片 */
.parse-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.parse-input-wrapper {
  position: relative;
  margin-bottom: 16rpx;
}

.parse-textarea {
  width: 100%;
  min-height: 360rpx;
  height: 360rpx;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
  line-height: 1.5;
}

.parse-clear {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666666;
}

.parse-examples {
  text-align: center;
  margin-bottom: 24rpx;
}

.examples-text {
  font-size: 26rpx;
  color: #FF6B8A;
  text-decoration: underline;
}

.voice-hint {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.parse-result {
  margin-top: 32rpx;
  padding-top: 32rpx;
  border-top: 2rpx solid #EEEEEE;
}

.timer-confirm,
.parse-records-list {
  margin-top: 16rpx;
  margin-bottom: 24rpx;
}

.confirm-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.confirm-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #666666;
}

.confirm-value {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.confirm-input {
  flex: 1;
  height: 64rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
}

.confirm-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 24rpx;
}

.confirm-actions .btn {
  flex: 1;
}

.parse-record-item {
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.parse-record-item.supplement {
  border-left: 6rpx solid #FF6B8A;
}

.parse-record-label {
  font-size: 24rpx;
  color: #FF6B8A;
  margin-bottom: 12rpx;
  font-weight: 600;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.result-content {
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.result-content text {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.result-content text:last-child {
  margin-bottom: 0;
}

/* 今日记录 */
.today-records {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
}

.records-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.records-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #F5F5F5;
}

.record-item:last-child {
  border-bottom: none;
}

.record-time-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.record-time {
  font-size: 28rpx;
  color: #333333;
}

.supplement-tag {
  font-size: 22rpx;
  color: #FF6B8A;
  background: rgba(255, 107, 138, 0.15);
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
}

.record-amount {
  font-size: 28rpx;
  color: #FF6B8A;
  font-weight: 500;
  margin-right: 24rpx;
}

.record-duration {
  font-size: 26rpx;
  color: #999999;
}

/* 模态框 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  background: #FFFFFF;
  border-radius: 32rpx;
  width: 80%;
  max-width: 600rpx;
  overflow: hidden;
}

.modal-header {
  padding: 32rpx;
  text-align: center;
  border-bottom: 2rpx solid #EEEEEE;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.modal-body {
  padding: 32rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #F8F8F8;
  border-radius: 16rpx;
}

.picker-text {
  font-size: 28rpx;
  color: #333333;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999999;
}

.modal-footer {
  display: flex;
  border-top: 2rpx solid #EEEEEE;
}

.modal-btn {
  flex: 1;
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  background: transparent;
  border: none;
  border-radius: 0;
}

.modal-btn::after {
  border: none;
}

.modal-btn-cancel {
  color: #666666;
  border-right: 2rpx solid #EEEEEE;
}

.modal-btn-confirm {
  color: #FF6B8A;
  font-weight: 500;
}

/* 示例 */
.example-item {
  padding: 20rpx;
  background: #F8F8F8;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.example-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}
