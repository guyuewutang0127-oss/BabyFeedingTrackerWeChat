/* 评估详情页样式 */

.container {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background: #FFF5F7;
}

.result-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #EEEEEE;
}

.result-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
}

.result-date {
  font-size: 26rpx;
  color: #999999;
}

.result-section {
  margin-bottom: 32rpx;
}

.result-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #FF6B8A;
}

/* 生长发育网格 */
.growth-grid {
  display: flex;
  gap: 24rpx;
}

.growth-item {
  flex: 1;
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
}

.growth-label {
  display: block;
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.growth-value {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.growth-status {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-bottom: 8rpx;
}

.growth-status.normal {
  background: rgba(82, 196, 26, 0.1);
  color: #52C41A;
}

.growth-status.mild,
.growth-status.mildHigh {
  background: rgba(250, 173, 20, 0.1);
  color: #FAAD14;
}

.growth-status.moderate,
.growth-status.moderateHigh,
.growth-status.severe,
.growth-status.severeHigh {
  background: rgba(255, 77, 79, 0.1);
  color: #FF4D4F;
}

.growth-percent {
  display: block;
  font-size: 24rpx;
  color: #999999;
}

/* 信息列表 */
.info-list {
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 24rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #EEEEEE;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

/* 喂养结果 */
.feeding-result {
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 24rpx;
}

.feeding-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.feeding-label {
  font-size: 28rpx;
  color: #666666;
  margin-right: 24rpx;
}

.feeding-status {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.feeding-status.normal {
  background: rgba(82, 196, 26, 0.1);
  color: #52C41A;
}

.feeding-status.warning {
  background: rgba(255, 77, 79, 0.1);
  color: #FF4D4F;
}

.suggestion-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

/* 综合建议 */
.overall-suggestion {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.8;
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 24rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 48rpx;
}

.btn {
  padding: 28rpx 80rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8FA3 100%);
  color: #FFFFFF;
}
