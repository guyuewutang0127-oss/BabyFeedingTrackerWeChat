/* 全局样式 */

/* CSS变量 */
page {
  --primary-color: #FF6B8A;
  --primary-light: #FFB6C1;
  --primary-gradient: linear-gradient(135deg, #FFE4E9 0%, #E8F4FF 100%);
  --bg-color: #FFF5F7;
  --card-bg: #FFFFFF;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --border-color: #EEEEEE;
  --success-color: #52C41A;
  --warning-color: #FAAD14;
  --error-color: #FF4D4F;
  --info-color: #1890FF;
  
  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.6;
}

/* 安全区域适配 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 卡片样式 */
.card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.card-title-icon {
  width: 8rpx;
  height: 32rpx;
  background: var(--primary-color);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  transition: all 0.3s;
}

.btn-primary {
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8FA3 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 138, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 138, 0.2);
}

.btn-secondary {
  background: #F5F5F5;
  color: var(--text-primary);
}

.btn-secondary:active {
  background: #EEEEEE;
}

.btn-danger {
  background: var(--error-color);
  color: #FFFFFF;
}

.btn-small {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  border-radius: 32rpx;
}

/* 悬浮按钮 */
.fab {
  position: fixed;
  right: 48rpx;
  bottom: 180rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  background: linear-gradient(135deg, #FF6B8A 0%, #FF8FA3 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 138, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: 300;
}

/* 输入框样式 */
.input-group {
  margin-bottom: 24rpx;
}

.input-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.input-field {
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.input-field:focus {
  border-color: var(--primary-light);
  background: #FFFFFF;
}

/* 选择器样式 */
.picker-wrapper {
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-value {
  font-size: 28rpx;
  color: var(--text-primary);
}

.picker-arrow {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.tag-primary {
  background: rgba(255, 107, 138, 0.1);
  color: var(--primary-color);
}

.tag-success {
  background: rgba(82, 196, 26, 0.1);
  color: var(--success-color);
}

.tag-warning {
  background: rgba(250, 173, 20, 0.1);
  color: var(--warning-color);
}

.tag-error {
  background: rgba(255, 77, 79, 0.1);
  color: var(--error-color);
}

/* 列表样式 */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--border-color);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-content {
  flex: 1;
}

.list-item-title {
  font-size: 30rpx;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.list-item-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.list-item-arrow {
  font-size: 28rpx;
  color: var(--text-tertiary);
  margin-left: 16rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
  text-align: center;
}

/* 模态框 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  background: #FFFFFF;
  border-radius: 32rpx;
  width: 80%;
  max-width: 600rpx;
  overflow: hidden;
}

.modal-header {
  padding: 32rpx;
  text-align: center;
  border-bottom: 2rpx solid var(--border-color);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-body {
  padding: 32rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

.modal-footer {
  display: flex;
  border-top: 2rpx solid var(--border-color);
}

.modal-btn {
  flex: 1;
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  background: transparent;
  border: none;
}

.modal-btn-cancel {
  color: var(--text-secondary);
  border-right: 2rpx solid var(--border-color);
}

.modal-btn-confirm {
  color: var(--primary-color);
  font-weight: 500;
}

/* 动画 */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.fade-in {
  animation: fadeIn 0.3s ease-out;
}

.slide-up {
  animation: slideUp 0.3s ease-out;
}

/* 工具类 */
.text-center { text-align: center; }
.text-left { text-align: left; }
.text-right { text-align: right; }

.font-bold { font-weight: 600; }
.font-normal { font-weight: 400; }

.mt-8 { margin-top: 16rpx; }
.mt-16 { margin-top: 32rpx; }
.mt-24 { margin-top: 48rpx; }

.mb-8 { margin-bottom: 16rpx; }
.mb-16 { margin-bottom: 32rpx; }
.mb-24 { margin-bottom: 48rpx; }

.ml-8 { margin-left: 16rpx; }
.mr-8 { margin-right: 16rpx; }

.p-16 { padding: 32rpx; }
.p-24 { padding: 48rpx; }

.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.flex-1 { flex: 1; }

.hidden { display: none; }
.block { display: block; }
